# ─── Jaded Rose Chatbot — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your real values.

# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Twilio / WhatsApp ────────────────────────────────────────────────────
# Twilio Console → Dashboard
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Your Twilio WhatsApp sender number
WHATSAPP_FROM_NUMBER=+14155238886

# ── Gmail ─────────────────────────────────────────────────────────────────
# Path to Google OAuth credentials file
GMAIL_CREDENTIALS_JSON=credentials.json
# The support inbox to monitor
GMAIL_SUPPORT_ADDRESS=support@jadedrose.com

# ── OpenAI ────────────────────────────────────────────────────────────────
# OpenAI API key (GPT-4o + embeddings)
OPENAI_API_KEY=sk-your-openai-api-key
# Chat model (gpt-4o, gpt-4o-mini, etc.)
OPENAI_MODEL=gpt-4o

# ── Pinecone ──────────────────────────────────────────────────────────────
# Pinecone console → API Keys
PINECONE_API_KEY=your-pinecone-api-key
# Name of the Pinecone index
PINECONE_INDEX=jaded-rose-chatbot

# ── Shopify ───────────────────────────────────────────────────────────────
# Your Shopify store URL
SHOPIFY_STORE_URL=https://jaded-rose.myshopify.com
# Shopify Admin API access token
SHOPIFY_ADMIN_API_KEY=shpat_your-admin-api-key

# ── Redis ─────────────────────────────────────────────────────────────────
# Redis connection string (conversation memory)
REDIS_URL=redis://localhost:6379/0

# ── Escalation ────────────────────────────────────────────────────────────
# Email address for human escalation alerts
ESCALATION_EMAIL=team@jadedrose.com

# ── Carrier API Keys ─────────────────────────────────────────────────────
# Royal Mail Tracking API
ROYAL_MAIL_API_KEY=your-royal-mail-api-key
# DHL Shipment Tracking API v2
DHL_API_KEY=your-dhl-api-key
# DPD Tracking API
DPD_API_KEY=your-dpd-api-key
